flutter/ephemeral/

# ffmpeg_shim build outputs (source under ffmpeg_shim/ is tracked; the
# compiled DLL is a release artifact built by scripts/build_ffmpeg_shim.ps1,
# same as the ffmpeg binaries under assets/bin/windows/).
ffmpeg_shim/*.dll
ffmpeg_shim/*.lib
ffmpeg_shim/*.o
ffmpeg_shim/*.def
ffmpeg_shim/*.exp

# Visual Studio user-specific files.
*.suo
*.user
*.userosscache
*.sln.docstates

# Visual Studio build-related files.
x64/
x86/

# Visual Studio cache files
# files ending in .cache can be ignored
*.[Cc]ache
# but keep track of directories ending in .cache
!*.[Cc]ache/
